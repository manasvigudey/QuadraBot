  <link name="RR_hip">
    <visual>
      <origin rpy="3.141592653589793 3.141592653589793 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://go1_description/meshes/hip.dae" scale="1 1 1"/>
