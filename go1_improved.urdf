               iyy="0.000619101213" iyz="-1.643194e-06" izz="0.00040057614"/>
    </inertial>
  </link>

  <link name="FL_hip_rotor">
    <visual>
      <origin rpy="0 1.5707963267948966 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.02" radius="0.035"/></geometry>
      <material name="green"/>
    </visual>
    <collision>
      <origin rpy="0 1.5707963267948966 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.02" radius="0.035"/></geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.089"/>
      <inertia ixx="0.000111842" ixy="0" ixz="0" iyy="5.9647e-05" iyz="0" izz="5.9647e-05"/>
